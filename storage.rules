rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Strict User Isolation for Storage Files
    // Users can only read/write files under their own path: users/{userId}/{folderName}/{allPaths=**}
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
