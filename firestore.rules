rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Management Rules for app_users collection
    match /app_users/{userId} {
      // Allow any authenticated user to read user documents to resolve duplicate profiles (by email/phone)
      allow read: if request.auth != null;
      
      // Allow only the owner to write/delete their own primary document
      allow write, delete: if request.auth != null && request.auth.uid == userId;
      
      // Strict isolation for all subcollections (drafts, cards, guests, templates, settings)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Legacy users collection support
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Global template and public read-only settings
    match /templates/{templateId} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin can update global templates
    }
  }
}
